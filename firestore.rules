rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        userDoc().data.role == 'admin';
    }

    function isDoctor() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        userDoc().data.role == 'doctor';
    }

    function isPatient() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        userDoc().data.role == 'patient';
    }

    match /users/{userId} {
      allow get: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();

      allow create: if signedIn() &&
        request.auth.uid == userId &&
        request.resource.data.uid == userId &&
        request.resource.data.role in ['patient', 'doctor'];

      allow update: if isAdmin() ||
        (signedIn() &&
          request.auth.uid == userId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'firstName',
            'lastName',
            'name',
            'email',
            'phone',
            'profileImageUrl',
            'loginMethod',
            'updatedAt'
          ]));

      allow delete: if isAdmin();

      match /favorites/{doctorId} {
        allow read, create, update, delete: if signedIn() &&
          request.auth.uid == userId;
      }
    }

    match /doctors/{doctorId} {
      allow read: if signedIn();

      allow create: if signedIn() &&
        request.auth.uid == doctorId &&
        request.resource.data.uid == doctorId &&
        request.resource.data.approved == false;

      allow update: if isAdmin() ||
        (signedIn() &&
          request.auth.uid == doctorId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'name',
            'email',
            'phone',
            'specialty',
            'designation',
            'available',
            'availableSlots',
            'profileImageUrl',
            'qualification',
            'experienceYears',
            'hospitalName',
            'bio',
            'averageConsultationMinutes',
            'updatedAt'
          ]));

      allow delete: if isAdmin();
    }

    match /health_profiles/{patientId} {
      allow read: if signedIn() && (
        request.auth.uid == patientId ||
        isAdmin() ||
        (isDoctor() && request.auth.uid in resource.data.doctorIds)
      );

      allow create: if signedIn() &&
        request.auth.uid == patientId &&
        request.resource.data.uid == patientId;

      allow update: if signedIn() && request.auth.uid == patientId;
      allow delete: if isAdmin();
    }

    match /health_cards/{patientId} {
      allow read, create, update: if signedIn() &&
        (request.auth.uid == patientId || isAdmin());
      allow delete: if isAdmin();
    }

    match /appointments/{appointmentId} {
      allow read: if signedIn() && (
        resource.data.patientId == request.auth.uid ||
        resource.data.doctorId == request.auth.uid ||
        isAdmin()
      );

      allow create: if isPatient() &&
        request.resource.data.patientId == request.auth.uid &&
        request.resource.data.status == 'Pending';

      allow update: if isAdmin() ||
        (isPatient() &&
          resource.data.patientId == request.auth.uid &&
          request.resource.data.patientId == resource.data.patientId &&
          request.resource.data.doctorId == resource.data.doctorId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'appointmentDate',
            'scheduledAt',
            'time',
            'slotId',
            'status',
            'updatedAt'
          ]) &&
          request.resource.data.status in ['Pending', 'Cancelled']) ||
        (isDoctor() &&
          resource.data.doctorId == request.auth.uid &&
          request.resource.data.patientId == resource.data.patientId &&
          request.resource.data.doctorId == resource.data.doctorId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'updatedAt',
            'completedAt'
          ]) &&
          request.resource.data.status in [
            'Pending',
            'Accepted',
            'Rejected',
            'In Consultation',
            'Completed',
            'Cancelled'
          ]);

      allow delete: if isAdmin();
    }

    match /appointment_slots/{slotId} {
      allow read: if signedIn();

      allow create: if signedIn() &&
        request.resource.data.patientId == request.auth.uid;

      allow update: if isAdmin() ||
        (signedIn() && resource.data.patientId == request.auth.uid) ||
        (isPatient() &&
          resource.data.booked == false &&
          request.resource.data.patientId == request.auth.uid) ||
        (isDoctor() && resource.data.doctorId == request.auth.uid);

      allow delete: if isAdmin();
    }

    match /prescriptions/{prescriptionId} {
      allow read: if signedIn() && (
        resource.data.patientId == request.auth.uid ||
        resource.data.doctorId == request.auth.uid ||
        isAdmin()
      );

      allow create: if isDoctor() &&
        request.resource.data.doctorId == request.auth.uid;

      allow update: if isAdmin() ||
        (isDoctor() && resource.data.doctorId == request.auth.uid);

      allow delete: if isAdmin();
    }

    match /medicines/{medicineId} {
      allow read: if signedIn() && (
        resource.data.patientId == request.auth.uid || isAdmin()
      );
      allow create: if isPatient() &&
        request.resource.data.patientId == request.auth.uid;
      allow update, delete: if signedIn() &&
        (resource.data.patientId == request.auth.uid || isAdmin());
    }

    match /timeline_events/{eventId} {
      allow read: if signedIn() && (
        resource.data.patientId == request.auth.uid || isAdmin()
      );
      allow create: if signedIn() && (
        request.resource.data.patientId == request.auth.uid ||
        isDoctor() ||
        isAdmin()
      );
      allow update, delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read, update: if signedIn() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if signedIn();
      allow delete: if isAdmin();
    }

    match /announcements/{announcementId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow read: if signedIn() &&
        request.auth.uid in resource.data.participants;

      allow create: if signedIn() &&
        request.resource.data.senderId == request.auth.uid &&
        request.auth.uid in request.resource.data.participants &&
        request.resource.data.receiverId in request.resource.data.participants;

      allow update: if signedIn() &&
        request.auth.uid in resource.data.participants;

      allow delete: if isAdmin();
    }

    match /call_requests/{requestId} {
      allow read: if signedIn() && (
        resource.data.requesterId == request.auth.uid ||
        resource.data.receiverId == request.auth.uid ||
        isAdmin()
      );
      allow create: if signedIn() &&
        request.resource.data.requesterId == request.auth.uid;
      allow update: if signedIn() && (
        resource.data.receiverId == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /emergency_requests/{requestId} {
      allow read: if signedIn() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if signedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /hospitals/{hospitalId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /emergency_contacts/{contactId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if signedIn();
      allow create: if isPatient() &&
        request.resource.data.patientId == request.auth.uid;
      allow update, delete: if signedIn() &&
        (resource.data.patientId == request.auth.uid || isAdmin());
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
